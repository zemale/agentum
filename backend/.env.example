PORT=3001
NODE_ENV=development
LOG_LEVEL=info
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentum?schema=public
REDIS_URL=redis://localhost:6379
IDEMPOTENCY_TTL=86400
SENTRY_DSN=
RATE_LIMIT_ENABLED=true
